# Docker Compose Environment Variables
# Copy this to .env and adjust for your environment

# JWT Secrets (change in production!)
JWT_ACCESS_SECRET=taskspace_access_secret_dev_2026
JWT_ACCESS_EXPIRES_IN=15m

JWT_REFRESH_SECRET=taskspace_refresh_secret_dev_2026
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Email (optional for dev, leave empty to only log reset links)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM="Team Flow <no-reply@teamflow.app>"
